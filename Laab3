import re
import torch
from transformers import pipeline

device = 0 if torch.cuda.is_available() else -1
model_name = "Qwen/Qwen2.5-0.5B-Instruct"

generator = pipeline(
    "text-generation",
    model=model_name,
    tokenizer=model_name,
    device=device
)

user_histories = {}
USER_ID = "colab_user"

def clean_text(text):
    text = text.replace("\r", " ").replace("\n", " ")
    text = re.sub(r"\s+", " ", text).strip()
    return text

def build_messages(history, user_text):
    messages = [
        {
            "role": "system",
            "content": (
                "You are a helpful chatbot. "
                "Reply only in English. "
                "Keep answers short and natural. "
                "Do not repeat yourself. "
                "Do not generate multiple similar sentences."
            )
        }
    ]

    for role, content in history[-6:]:
        messages.append({"role": role, "content": content})

    messages.append({"role": "user", "content": user_text})
    return messages

def ask_model(messages):
    prompt = generator.tokenizer.apply_chat_template(
        messages,
        tokenize=False,
        add_generation_prompt=True
    )

    result = generator(
        prompt,
        max_new_tokens=80,
        do_sample=True,
        temperature=0.7,
        top_p=0.9,
        pad_token_id=generator.tokenizer.eos_token_id,
        return_full_text=False
    )[0]["generated_text"]

    answer = clean_text(result)

    sentences = re.split(r"(?<=[.!?])\s+", answer)
    uniq = []
    seen = set()

    for s in sentences:
        s = s.strip()
        key = s.lower()
        if s and key not in seen:
            seen.add(key)
            uniq.append(s)

    answer = " ".join(uniq).strip()

    if not answer:
        answer = "I don't know what to say."

    return answer

def clear_history():
    user_histories[USER_ID] = []
    print("History cleared")

def chat():
    if USER_ID not in user_histories:
        user_histories[USER_ID] = []

    print("Bot started")
    print("Commands: /clear, /exit")

    while True:
        text = input("You: ").strip()

        if not text:
            continue

        if text == "/exit":
            print("Chat ended")
            break

        if text == "/clear":
            clear_history()
            continue

        messages = build_messages(user_histories[USER_ID], text)

        try:
            answer = ask_model(messages)
        except Exception as e:
            print("Error:", e)
            continue

        user_histories[USER_ID].append(("user", text))
        user_histories[USER_ID].append(("assistant", answer))

        print("Bot:", answer)

chat()
